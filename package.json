{
  "name": "@wnddd8339/flow",
  "version": "0.6.2",
  "description": "Project specification document initializer for AI coding tools",
  "type": "module",
  "license": "MIT",
  "author": "wnddd839 (https://github.com/wnddd839)",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "flow": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wnddd839/flow.git"
  },
  "homepage": "https://wnddd839.github.io/flow/",
  "bugs": {
    "url": "https://github.com/wnddd839/flow/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "cursor",
    "claude",
    "spec",
    "documentation"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "npm run lint && npm run typecheck && npm test",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
